generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  date      String
  time      String
  timezone  String
  meetLink  String
  createdAt DateTime @default(now())

  @@unique([date, time])
}